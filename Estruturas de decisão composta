#include <stdio.h>

int main(){
/*utilizar a estrutura if-else para criar programas que tomam decisões
no exemplo, utilizado para comparar valores */
   int numero1;
   int numero2;

   numero1 = 10;
   numero2 = 5; 

   if(numero1 > numero2) {
    printf("O numero 1 é maior que numero 2\n");
   }else{
    printf("O numero 2 é maior que numero 2 \n");

   }
    
}
