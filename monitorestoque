#include<stdio.h>

/*O programa desenvolvido verifica três condições de segurança: 
temperatura, umidade e nível de estoque. 
Caso alguma delas esteja fora dos limites seguros, o programa emitirá um alerta. */

int main(){

    float temperatura, umidade;
    unsigned int estoque, estoqueMinimo = 500;

    printf("Entre com a temperatuta: ");
    scanf("%f", &temperatura);
    printf("Entre com a umidade: ");
    scanf("%f", &umidade);
    printf("Entre com o estoque: ");
    scanf("%u", &estoque);
      printf("\n\n");//pular duas linhas

    if( temperatura > 30){
        printf("Temperatura: Está alta - PERIGO \n");
    } else{ 
        printf("Temperatura: Dentro dos parâmentos \n");
    }
     if (umidade > 50){
    printf("Umidade Elevada.\n");
    } else {
        printf("Umidade está dentro dos parâmentros \n");
    }
    if (estoque > estoqueMinimo){
        printf("Estoque esta normal! \n");
    } else {
        printf("Estoque em nivel minimo \n");
    }
    printf("infomrações coletadas:\n");

    printf("\ninfomrações coletadas:\n");
    printf("Temperatura: %dºC",(int) temperatura); // converão float para int 
    printf(" Umidade %d",(int) umidade); // converão float para int 
    printf(" Estoque: %u\n",estoque);

    printf("fim"); 
  
}
